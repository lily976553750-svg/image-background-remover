# Remove.bg API Key
# Get your free API key at https://www.remove.bg/api
# 
# For Cloudflare Pages, set this via:
# 1. Cloudflare Dashboard > Pages > Settings > Environment variables
# 2. Or: wrangler secret put REMOVEBG_API_KEY

REMOVEBG_API_KEY=your_api_key_here

# Google OAuth
# Authorized redirect URI:
# https://bg-remover.xyz/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Generate a long random value for signed auth cookies.
# Example: openssl rand -base64 32
AUTH_SECRET=your_random_auth_secret_here

# Optional but recommended in production.
SITE_URL=https://bg-remover.xyz
AUTH_REDIRECT_URI=https://bg-remover.xyz/api/auth/callback/google

# Cloudflare D1
# Binding name expected by Pages Functions: DB
# Create and bind with:
# wrangler d1 create bg-remover-prod
# wrangler d1 migrations apply bg-remover-prod --remote
